# Kpler credentials. Do not commit real credentials.
KPLER_USERNAME=
# KPLER_EMAIL is also accepted if that is how your Kpler login is named.
# KPLER_EMAIL=
KPLER_PASSWORD=

# Dynamic date controls.
# Defaults: KPLER_START_DATE=2018-01-01 and KPLER_FORWARD_DAYS=45.
KPLER_START_DATE=2018-01-01
KPLER_FORWARD_DAYS=45
# Optional hard override:
# KPLER_END_DATE=2026-07-01

# Runtime tuning.
KPLER_CONCURRENCY=2
KPLER_RETRY_COUNT=3
KPLER_RETRY_BACKOFF_SECONDS=10
KPLER_VERIFY_TLS=true
KPLER_USER_AGENT=US-Balances-Kpler-Pull/1.0
