# Kpler API v2 key. Do not commit real credentials.
# Preferred: paste only the key value after "Basic ".
KPLER_API_KEY=
# Alternative: paste the complete Authorization header value.
# KPLER_API_V2_BASIC_AUTH="Basic ..."
# Optional non-production override; the default is https://api.kpler.com/v2/cargo.
# KPLER_API_BASE_URL=

# Dynamic date controls.
# Defaults: KPLER_START_DATE=2018-01-01 and KPLER_FORWARD_DAYS=45.
KPLER_START_DATE=2018-01-01
KPLER_FORWARD_DAYS=45
# Optional hard override:
# KPLER_END_DATE=2026-07-01

# Runtime tuning.
KPLER_CONCURRENCY=2
KPLER_RETRY_COUNT=3
KPLER_RETRY_BACKOFF_SECONDS=2
KPLER_VERIFY_TLS=true
KPLER_PULL_FAMILIES=balance_guides
KPLER_PULL_NAMES=
KPLER_PULL_ROUTE_GROUPS=
KPLER_USER_AGENT=US-Balances-Kpler-Pull/2.0
