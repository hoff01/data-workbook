{
  "name": "us-balances-eia-pipelines",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "weekly": "node --import tsx src/run_weekly_pipeline.ts",
    "weekly:raw": "python3 src/weekly_xls.py",
    "monthly": "node --import tsx src/monthly.ts",
    "capacity": "python3 src/eia_capacity.py",
    "capacity:refineries": "python3 src/refinery_capacity_units.py",
    "power:dfo": "python3 power_generation_dfo/pull_power_generation_dfo.py",
    "power:dfo:hourly": "python3 power_generation_dfo/hourly_dfo_forecast.py",
    "power:dfo:all": "npm run power:dfo && npm run power:dfo:hourly",
    "kpler": "python3 src/kpler_pull.py",
    "kpler:dry-run": "python3 src/kpler_pull.py --dry-run",
    "kpler:preflight": "python3 src/kpler_pull.py --preflight",
    "kpler:auth-check": "python3 src/kpler_pull.py --check-auth",
    "kpler:padd1:eia": "python3 src/kpler_padd1_eia_split.py",
    "kpler:padd1:eia:preflight": "python3 src/kpler_padd1_eia_split.py --preflight",
    "padd1": "python3 src/padd_1_distillate.py",
    "clean:eia": "python3 src/clean_eia_outputs.py",
    "export:headers": "python3 src/export_raw_headers.py",
    "export:weekly": "python3 src/export_raw_headers.py weekly",
    "export:weekly:clean": "python3 src/export_raw_headers.py weekly --skip-weekly-raw-archive",
    "export:monthly": "python3 src/export_raw_headers.py monthly",
    "export:bulk-series": "python3 src/export_bulk_series.py",
    "Bulk_series_pull": "node --import tsx src/bulk_series_pull.ts",
    "export:headers:clean": "python3 src/export_raw_headers.py all --skip-weekly-raw-archive",
    "verify:weekly": "node --import tsx src/verify_weekly_freshness.ts",
    "verify:monthly": "node --import tsx src/verify_monthly_freshness.ts",
    "verify:dashboard": "node --import tsx src/verify_dashboard_freshness.ts",
    "verify:weekly-call-outputs": "node --import tsx src/verify_weekly_call_outputs.ts",
    "validate": "python3 src/validate_outputs.py",
    "data:check": "python3 src/data_health_check.py",
    "build:all": "npm run update:all",
    "build:balances": "node --import tsx src/build_balance_dashboards.ts",
    "update:weekly": "node --import tsx src/update_pipeline.ts weekly",
    "update:monthly": "node --import tsx src/update_pipeline.ts monthly",
    "update:other": "node --import tsx src/update_pipeline.ts other",
    "update:power-dfo": "node --import tsx src/update_pipeline.ts power-dfo",
    "update:all": "node --import tsx src/update_pipeline.ts all",
    "dashboard:server": "node --import tsx src/dashboard_update_server.ts",
    "dashboard:open": "node --import tsx src/open_dashboard.ts",
    "dashboard:open:diesel": "node --import tsx src/open_dashboard.ts diesel",
    "dashboard:open:jet": "node --import tsx src/open_dashboard.ts jet",
    "trace:dashboard:performance": "node scripts/dashboard_performance_trace.mjs",
    "trace:dashboard:optimize": "node scripts/dashboard_performance_trace.mjs --product=all",
    "test:dashboard-runner": "node --import tsx scripts/test_weekly_call_archive_freshness.ts && node --import tsx scripts/test_update_data_fingerprint.ts && node scripts/test_update_pipeline_entrypoint.mjs && node scripts/test_dashboard_update_server.mjs",
    "verify:windows": "node scripts/verify_windows_portability.mjs",
    "typecheck": "tsc --noEmit"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  }
}
