# Copy this file to .env.local. Real credentials stay local because .env.local is ignored by git.

# Kpler Cargo Flows API v2 key. Paste only the value after "Basic ".
KPLER_API_KEY=

# Alternative: use the complete Authorization header value instead of KPLER_API_KEY.
# KPLER_API_V2_BASIC_AUTH="Basic ..."

# Optional source keys and safe Kpler defaults.
EIA_API_KEY=
KPLER_START_DATE=2018-01-01
KPLER_FORWARD_DAYS=45
KPLER_CONCURRENCY=2
KPLER_PULL_FAMILIES=balance_guides
